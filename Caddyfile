# Caddy obtém e renova HTTPS (Let's Encrypt) automaticamente para o hostname abaixo,
# desde que ele aponte para o IP da VPS (o hostname grátis da Hostinger já aponta).
#
# Para usar SEU domínio: troque a linha do hostname por "app.seudominio.com".
# Para teste rápido só por IP (sem HTTPS): troque por ":80".

srv1783148.hstgr.cloud {
	encode zstd gzip
	reverse_proxy app:3000
}
