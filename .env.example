# Copie para .env e preencha. O .env NÃO é versionado.
# A anon/publishable key é segura no client (protegida por RLS no Supabase).

SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_PROJECT_ID=seu_project_id
SUPABASE_PUBLISHABLE_KEY=sua_anon_key

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PROJECT_ID=seu_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key

# SERVER-ONLY — bypassa RLS. NUNCA versionar o valor real; definir só no ambiente
# do servidor (Lovable Cloud / VPS). Usada por src/integrations/supabase/client.server.ts.
SUPABASE_SERVICE_ROLE_KEY=definir_no_servidor
